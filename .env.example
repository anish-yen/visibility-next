# Copy values into backend/.env and frontend/.env.local (see README).

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Required for audit LLM pipeline (prompts, visibility sim, briefs)
GEMINI_API_KEY=

REDIS_URL=
DATABASE_URL=

# Next.js (same URL and anon key as above; exposed to the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# FastAPI base URL for dashboard fetches (default http://localhost:8000 if unset)
NEXT_PUBLIC_API_URL=http://localhost:8000
